Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"DataStatistic", "[", "x_List", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"mean", ",", 
       RowBox[{"tValue", "=", "1.14"}], ",", 
       RowBox[{"deltaB", "=", "0.0095"}], ",", "uncertainty"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"MeanStandardDeviation", "[", "data_", "]"}], ":=", 
       RowBox[{
        RowBox[{"StandardDeviation", "[", "data", "]"}], "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"Length", "[", "data", "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"DeltaA", "[", 
        RowBox[{"data_", ",", "t_"}], "]"}], ":=", 
       RowBox[{"t", "*", 
        RowBox[{"StandardDeviation", "[", "data", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Uncertainty", "[", 
        RowBox[{"data_", ",", "t_", ",", "deltaB_"}], "]"}], ":=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"DeltaA", "[", 
           RowBox[{"data", ",", "t"}], "]"}], "^", "2"}], "+", 
         RowBox[{"deltaB", "^", "2"}]}], "]"}]}], ";", 
      RowBox[{"mean", "=", 
       RowBox[{"Mean", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"uncertainty", "=", 
       RowBox[{"Uncertainty", "[", 
        RowBox[{"x", ",", "tValue", ",", "deltaB"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Mean: \>\"", ",", "mean"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Standard Deviation: \>\"", ",", 
        RowBox[{"StandardDeviation", "[", "x", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Mean Standard Deviation: \>\"", ",", 
        RowBox[{"MeanStandardDeviation", "[", "x", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<deltaA: \>\"", ",", 
        RowBox[{"DeltaA", "[", 
         RowBox[{"x", ",", "tValue"}], "]"}]}], "]"}], ";", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<deltaB: \>\"", ",", "deltaB"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Uncertainty: \>\"", ",", "uncertainty"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{"Around", "[", 
        RowBox[{"mean", ",", "uncertainty"}], "]"}], "]"}]}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ShowFitPlot", "[", 
    RowBox[{
    "dataX_List", ",", "dataY_List", ",", "xName_", ",", "yName_", ",", 
     "plotName_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"data", ",", "fitModel"}], "}"}], ",", 
     RowBox[{
      RowBox[{"data", "=", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"dataX", ",", "dataY"}], "}"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"fitModel", "=", 
       RowBox[{"LinearModelFit", "[", 
        RowBox[{"data", ",", "x", ",", "x"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Best Fit Equation: \>\"", ",", 
        RowBox[{"fitModel", "[", "\"\<BestFit\>\"", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"Show", "[", 
        RowBox[{
         RowBox[{"ListPlot", "[", 
          RowBox[{"data", ",", 
           RowBox[{"PlotStyle", "->", "Red"}], ",", 
           RowBox[{"PlotLabel", "->", "plotName"}], ",", 
           RowBox[{"AxesLabel", "->", 
            RowBox[{"{", 
             RowBox[{"xName", ",", "yName"}], "}"}]}]}], "]"}], ",", 
         RowBox[{"Plot", "[", 
          RowBox[{
           RowBox[{"fitModel", "[", "x", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", 
             RowBox[{"Min", "[", "dataX", "]"}], ",", 
             RowBox[{"Max", "[", "dataX", "]"}]}], "}"}]}], "]"}]}], "]"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Return", "[", 
       RowBox[{
        RowBox[{"fitModel", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ShowFitPlot", "[", 
    RowBox[{"dataX_List", ",", "dataY_List", ",", "xName_", ",", "yName_"}], 
    "]"}], ":=", 
   RowBox[{"ShowFitPlot", "[", 
    RowBox[{
    "dataX", ",", "dataY", ",", "xName", ",", "yName", ",", "\"\<\>\""}], 
