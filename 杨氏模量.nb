Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"DataStatistic", "[", "x_List", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mean", ",", 
        RowBox[{"tValue", "=", "1.14"}], ",", 
        RowBox[{"deltaB", "=", "0.0004"}], ",", "uncertainty"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"MeanStandardDeviation", "[", "data_", "]"}], ":=", 
        RowBox[{
         RowBox[{"StandardDeviation", "[", "data", "]"}], "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"Length", "[", "data", "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"DeltaA", "[", 
         RowBox[{"data_", ",", "t_"}], "]"}], ":=", 
        RowBox[{"t", "*", 
         RowBox[{"StandardDeviation", "[", "data", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Uncertainty", "[", 
         RowBox[{"data_", ",", "t_", ",", "deltaB_"}], "]"}], ":=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"DeltaA", "[", 
            RowBox[{"data", ",", "t"}], "]"}], "^", "2"}], "+", 
          RowBox[{"deltaB", "^", "2"}]}], "]"}]}], ";", 
       RowBox[{"mean", "=", 
        RowBox[{"Mean", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"uncertainty", "=", 
        RowBox[{"Uncertainty", "[", 
         RowBox[{"x", ",", "tValue", ",", "deltaB"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Mean: \>\"", ",", "mean"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Standard Deviation: \>\"", ",", 
         RowBox[{"StandardDeviation", "[", "x", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Mean Standard Deviation: \>\"", ",", 
         RowBox[{"MeanStandardDeviation", "[", "x", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<deltaA: \>\"", ",", 
         RowBox[{"DeltaA", "[", 
          RowBox[{"x", ",", "tValue"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<deltaB: \>\"", ",", "deltaB"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Uncertainty: \>\"", ",", "uncertainty"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Return", "[", 
        RowBox[{"Around", "[", 
         RowBox[{"mean", ",", "uncertainty"}], "]"}], "]"}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ShowFitPlot", "[", 
